{
    "name": "dcodegroup/bugsnag-laravel-mcp",
    "description": "Basic MCP for integrating Bugsnag into AI workflows",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Dcodegroup\\BugsnagLaravelMcp\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Kath Young",
            "email": "Kath@dcodegroup.com.au"
        },
        {
            "name": "Dcode Group",
            "email": "forge@dcodegroup.com.au"
        }        
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "require": {
        "laravel/mcp": "^0.7.0",
        "spatie/laravel-data": "^4.23",
        "saloonphp/saloon": "^4.0",
        "saloonphp/laravel-plugin": "^4.0",
        "saloonphp/pagination-plugin": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.7",
        "phpstan/phpstan": "^2.1"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dcodegroup\\BugsnagLaravelMcp\\Providers\\BugsnagMcpProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
